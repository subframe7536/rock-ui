{
  "name": "rock-ui",
  "version": "0.0.0",
  "description": "Opinioned SolidJS component library.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.*"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/index.jsx",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "solid": "./dist/*/index.jsx",
      "default": "./dist/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "qa": "oxfmt && oxlint --fix && tsc --noEmit",
    "release": "bun run test --run && bumpp",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@solid-primitives/props": "^3.2.2",
    "@solid-primitives/refs": "^1.1.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.90",
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@types/bun": "^1.3.9",
    "@unocss/eslint-plugin": "^66.6.0",
    "@unocss/reset": "^66.6.0",
    "bumpp": "^10.4.1",
    "cls-variant": "^1.0.2",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^28.0.0",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "rolldown-plugin-unocss": "^0.1.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "unocss": "^66.6.0",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-completion": "^0.3.0",
    "vite": "8.0.0-beta.13",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "solid-js": "^1.9.11"
  },
  "overrides": {
    "@unocss/inspector": "npm:has-flag",
    "vite": "8.0.0-beta.13"
  }
}
