{
  "name": "rock-ui",
  "version": "0.0.0",
  "description": "Opinioned SolidJS component library.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.*"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "bun vite serve playground",
    "play:build": "bun vite build playground",
    "test": "bun vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "fix-oxlint": "bun -e \"const p=process.argv[1],f=Bun.file(p),t=await f.text();await Bun.write(p,t.replace(/jsPlugins/g,'//jsPlugins'));await Bun.write(p,t)\" .oxlintrc.json",
    "oxc": "bun run fix-oxlint && oxlint --fix && oxfmt",
    "qa": "bun run --parallel oxc typecheck",
    "release": "bun run test --run && bumpp",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@corvu/utils": "^0.4.2",
    "@kobalte/core": "^0.13.11",
    "cls-variant": "^1.1.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.93",
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@types/bun": "^1.3.9",
    "@unocss/eslint-plugin": "^66.6.0",
    "@unocss/reset": "^66.6.0",
    "bumpp": "^10.4.1",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "rolldown-plugin-unocss": "^0.1.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "unocss": "^66.6.0",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-completion": "^0.3.0",
    "valibot": "^1.2.0",
    "vite": "8.0.0-beta.13",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@unocss/preset-wind4": "^66.6.0",
    "solid-js": "^1.9.11",
    "typescript": "^5.9.3",
    "unocss": "^66.6.0"
  },
  "overrides": {
    "@unocss/inspector": "npm:has-flag",
    "vite": "8.0.0-beta.13"
  }
}
