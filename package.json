{
  "name": "@subf/rock-ui",
  "version": "0.0.1",
  "description": "Opinioned SolidJS component library.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "subframe7536",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "solid": "./dist/index.jsx",
      "default": "./dist/index.mjs",
      "type": "./dist/index.d.mts"
    },
    "./package.json": "./package.json",
    "./tw4.css": "./dist/tw4.css",
    "./tw3.css": "./dist/tw3.css",
    "./unocss-preset-theme": "./dist/unocss-preset-theme.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun --bun tsdown",
    "dev": "bun --bun tsdown --watch",
    "docs": "bun run build && bun --bun vite serve docs",
    "docs:build": "bun run build && bun --bun vite build docs",
    "test": "bun --bun vitest",
    "lint": "bun --bun oxlint",
    "format": "bun --bun oxfmt",
    "typecheck": "tsc --noEmit",
    "fix-oxlint": "bun -e \"const p=process.argv[1],f=Bun.file(p),t=await f.text();await Bun.write(p,t.replace(/jsPlugins/g,'//jsPlugins'));await Bun.write(p,t)\" .oxlintrc.json",
    "oxc": "bun run fix-oxlint && oxlint --fix && oxfmt",
    "qa": "bun run --parallel oxc typecheck",
    "release": "bun run test --run && bumpp",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@kobalte/core": "~0.13.11",
    "@kobalte/utils": "*",
    "cls-variant": "^1.2.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@types/bun": "^1.3.10",
    "@unocss/eslint-plugin": "^66.6.6",
    "@unocss/reset": "^66.6.6",
    "bumpp": "^10.4.1",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.0.0",
    "oxc-parser": "^0.121.0",
    "oxc-walker": "^0.7.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown-plugin-unocss": "^0.1.0",
    "shiki": "^4.0.2",
    "solid-toaster": "^0.1.3",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-completion": "^0.3.0",
    "valibot": "^1.3.1",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "oxc-parser": "^0.119.0",
    "oxc-walker": "^0.7.0",
    "solid-js": "^1.9.11",
    "unocss": "^66.6.6"
  },
  "peerDependenciesMeta": {
    "oxc-parser": {
      "optional": true
    },
    "oxc-walker": {
      "optional": true
    },
    "unocss": {
      "optional": true
    }
  },
  "overrides": {
    "@unocss/inspector": "npm:has-flag",
    "vite": "^8.0.0"
  },
  "inlinedDependencies": {
    "valibot": "1.3.1"
  }
}
