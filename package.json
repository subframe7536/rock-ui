{
  "name": "moraine",
  "version": "0.2.2",
  "description": "Comprehensive SolidJS component library with atomic class styling.",
  "keywords": [
    "components",
    "kobalte",
    "solid",
    "solidjs",
    "tailwindcss",
    "ui",
    "unocss"
  ],
  "homepage": "https://github.com/subframe7536/moraine#readme",
  "bugs": {
    "url": "https://github.com/subframe7536/moraine/issues"
  },
  "license": "MIT",
  "author": "subframe7536",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subframe7536/moraine.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "solid": "./dist/index.jsx",
      "default": "./dist/index.mjs",
      "type": "./dist/index.d.mts"
    },
    "./package.json": "./package.json",
    "./tw4.css": "./dist/tw4.css",
    "./tw3.css": "./dist/tw3.css",
    "./icon.css": "./dist/icon.css",
    "./unocss": "./dist/unocss.mjs",
    "./tailwind": "./dist/tailwind.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun --bun tsdown",
    "dev": "bun run docs:dev",
    "docs": "bun run build && bun run docs:dev",
    "docs:dev": "vite serve docs",
    "docs:build": "bun run build && vite build docs",
    "test": "vitest",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "oxc": "oxlint --fix && oxfmt",
    "qa": "bun run --parallel oxc typecheck",
    "release": "bun run test --run && bumpp --all",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "cls-variant": "^1.2.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.108",
    "@iconify/tailwind": "1.2.0",
    "@solidjs/router": "^0.16.1",
    "@solidjs/testing-library": "^0.8.10",
    "@subf/config": "^0.2.1",
    "@subf/unocss": "^0.2.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "bumpp": "^11.1.0",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.1.0",
    "oxc-parser": "^0.131.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "rolldown-plugin-unocss": "^0.1.0",
    "shiki": "^4.0.2",
    "solid-toaster": "^0.1.5",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0",
    "vite": "^8.0.13",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@iconify/tailwind": "1.2.0",
    "@subf/unocss": "^0.2.0",
    "solid-js": "^1.9.13",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@iconify/tailwind": {
      "optional": true
    },
    "@subf/unocss": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "valibot": "1.4.0"
  }
}
